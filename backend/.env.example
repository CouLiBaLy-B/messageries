# --- App ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
APP_URL=http://localhost:8080

# --- CORS / Origins ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=messaging
DB_PASSWORD=messaging_dev_pwd
DB_NAME=messaging
DB_SSL=false

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
JWT_SECRET=change_me_super_long_random_string_min_64_chars_in_production
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=messaging-attachments
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_admin_password
S3_FORCE_PATH_STYLE=true

# --- Limites ---
MAX_MESSAGE_LENGTH=4000
MAX_ATTACHMENT_MB=10
MAX_ATTACHMENTS_PER_MESSAGE=5
RATE_LIMIT_MESSAGES_PER_MINUTE=30
RATE_LIMIT_WS_EVENTS_PER_MINUTE=120

# --- ClamAV ---
CLAMAV_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# --- Phase 2 : Chiffrement enveloppe ---
ENCRYPT_MESSAGE_BODY=true
KMS_DRIVER=local
# Génère 32 bytes random en base64 : `openssl rand -base64 32`
# Format multi-clés : "id1:base64,id2:base64", clé active = KMS_LOCAL_ACTIVE
KMS_LOCAL_KEYS=dev-key-1:8b3J5p3xCq8mE+rNc7sV1WqA9oZqL6f0YtVjK2dGq5w=
KMS_LOCAL_ACTIVE=dev-key-1
# AWS_KMS_KEY_ARN=arn:aws:kms:eu-west-1:111122223333:key/abcd...

# --- Outbox worker ---
OUTBOX_WORKER_ENABLED=true

# --- Email ---
EMAIL_DRIVER=log
EMAIL_FROM=noreply@example.com
EMAIL_THROTTLE_MINUTES=10
