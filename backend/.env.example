# --- App ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
APP_URL=http://localhost:8080

# --- CORS / Origins ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=messaging
DB_PASSWORD=messaging_dev_pwd
DB_NAME=messaging
DB_SSL=false

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
# ⚠️ Générer en local avec : openssl rand -hex 48
JWT_SECRET=REPLACE_ME_RUN_openssl_rand_hex_48
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=messaging-attachments
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_admin_password
S3_FORCE_PATH_STYLE=true

# --- Limites ---
MAX_MESSAGE_LENGTH=4000
MAX_ATTACHMENT_MB=10
MAX_ATTACHMENTS_PER_MESSAGE=5
RATE_LIMIT_MESSAGES_PER_MINUTE=30
RATE_LIMIT_WS_EVENTS_PER_MINUTE=120

# --- ClamAV ---
CLAMAV_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# --- Phase 2 : Chiffrement enveloppe ---
ENCRYPT_MESSAGE_BODY=true
KMS_DRIVER=local
# ⚠️ Générer une vraie clé en local avec :
#    npx ts-node scripts/gen-kms-key.ts dev-key-1
# Puis coller ci-dessous au format "id:base64"
KMS_LOCAL_KEYS=REPLACE_WITH_OUTPUT_OF_gen-kms-key.ts
KMS_LOCAL_ACTIVE=dev-key-1
# AWS_KMS_KEY_ARN=arn:aws:kms:eu-west-1:111122223333:key/...

# --- Outbox worker ---
OUTBOX_WORKER_ENABLED=true

# --- Email ---
EMAIL_DRIVER=log
EMAIL_FROM=noreply@example.com
EMAIL_THROTTLE_MINUTES=10

# --- Phase 4 : Observabilité ---
METRICS_ENABLED=false
METRICS_NAMESPACE=Messaging
AWS_REGION=eu-west-3
TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=messaging-api
LOG_LEVEL=info
APP_VERSION=0.8.0

# --- Phase 5 : NATS JetStream + WS Gateway dédié ---
NATS_ENABLED=false
NATS_URL=nats://localhost:4222
NATS_STREAM=MESSAGING_EVENTS
NATS_REPLICAS=1
NATS_TLS=false
WS_GATEWAY_DEDICATED=false

# --- Phase 6 : OpenSearch ---
SEARCH_ENABLED=false
OPENSEARCH_ENDPOINT=
OPENSEARCH_INDEX=messaging_messages
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_TLS=true
